{
  "eslint.enable": true,
  "eslint.run": "onType",
  "eslint.validate": ["javascript", "javascriptreact"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,
  "files.associations": {
    "*.jsx": "javascriptreact"
  }
}
